{
  "name": "tiferet-yaakov-calendar",
  "version": "1.0.0",
  "private": false,
  "description": "Daily zmanim for Kokhav Yaakov and Tel Zion",
  "author": {
    "name": "Yehuda Israel",
    "email": "Yehuda_Fievel@yahoo.com"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "scripts": {
    "react-start": "vite",
    "electron-start": "wait-on http://localhost:3000 && yarn electron",
    "electron": "ELECTRON_DISABLE_SANDBOX=1 electron electron",
    "start": "concurrently \"yarn react-start\" \"yarn electron-start\"",
    "build": "vite build",
    "serve": "vite preview",
    "postbuild": "cp ./electron.js ./build/electron.js",
    "postinstall": "electron-builder install-app-deps",
    "package": "BUILD=true DEBUG=electron-builder electron-builder --dir",
    "builder": "BUILD=true electron-builder",
    "release": "yarn build && yarn builder"
  },
  "main": "electron.js",
  "build": {
    "publish": null,
    "appId": "com.example.electron-cra",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "files": [
      "build/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
